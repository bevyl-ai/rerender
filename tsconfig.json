{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "remotion": ["./src/remotion.ts"],
      "@remotion/transitions": ["./src/transitions/index.ts"],
      "@remotion/transitions/slide": ["./src/transitions/presentations/slide.tsx"],
      "@remotion/transitions/fade": ["./src/transitions/presentations/fade.tsx"],
      "@remotion/transitions/wipe": ["./src/transitions/presentations/wipe.tsx"],
      "@remotion/media-utils": ["./src/media-utils/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src", "demo", "render", "compat"]
}
