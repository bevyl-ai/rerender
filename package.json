{
  "name": "remover",
  "version": "0.0.0",
  "description": "Drop-in, MIT Remotion whose renderer is a parallel recording of the preview — slice the timeline across N browsers, record, stitch.",
  "license": "MIT",
  "author": "Noah Lindner",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "render": "tsx render/render.ts",
    "compat": "tsx compat/check.ts",
    "compat:results": "tsx compat/results.ts",
    "compat:studio": "tsx compat/studio.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@puppeteer/browsers": "^3.0.5",
    "@remotion/cli": "^4.0.484",
    "@remotion/media-utils": "^4.0.484",
    "@remotion/transitions": "^4.0.484",
    "@types/node": "^26.0.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^25.2.1",
    "remotion": "^4.0.484",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
