{
  "name": "rerender",
  "version": "0.0.0",
  "description": "Drop-in, MIT-licensed Remotion alternative. Renders real DOM to MP4 with WebCodecs and mediabunny, in a browser tab or fanned across parallel headless-Chrome workers. No ffmpeg.",
  "license": "MIT",
  "author": "Noah Lindner",
  "homepage": "https://rerender.video",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Octember/rerender.git"
  },
  "bugs": {
    "url": "https://github.com/Octember/rerender/issues"
  },
  "keywords": [
    "remotion",
    "video",
    "react",
    "webcodecs",
    "mp4",
    "animation",
    "renderer"
  ],
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./extract": "./src/extract/index.ts",
    "./media-parser": "./src/media-parser/index.ts"
  },
  "files": [
    "bin",
    "src",
    "render",
    "cloud",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "rerender": "bin/rerender.mjs"
  },
  "scripts": {
    "rerender": "tsx src/cli.ts",
    "studio": "tsx src/cli.ts studio",
    "dev": "vite",
    "build": "vite build",
    "deploy": "npm run build && npx wrangler deploy",
    "test": "npm run test:extract && vite build && tsx test/export.test.ts",
    "test:export": "tsx test/export.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "check": "biome check .",
    "knip": "knip",
    "publint": "publint",
    "test:extract": "tsx test/extract-sample-table.test.ts && tsx test/frame-store.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@mediabunny/aac-encoder": "^1.49.0",
    "@puppeteer/browsers": "^3.0.5",
    "@remotion/google-fonts": "^4.0.484",
    "@remotion/zod-types": "^4.0.484",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.28.1",
    "mediabunny": "^1.49.0",
    "puppeteer-core": "^25.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.22.4",
    "vite": "^6.4.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "knip": "^6.23.0",
    "publint": "^0.3.21",
    "remotion": "^4.0.484",
    "typescript": "^5.6.0"
  }
}
